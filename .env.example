# Copy to .env.local and fill in real values. Never commit .env.local.
# Production values live only in Vercel project settings.

# ── MongoDB ──────────────────────────────────────────────
# Required by /api/* handlers and the Auth.js MongoDBAdapter.
MONGODB_URI=mongodb://localhost:27017/ginasio-xl
# Optional: override the database name (defaults to "ginasio-xl").
# MONGODB_DB_NAME=ginasio-xl

# ── Auth.js ──────────────────────────────────────────────
# Random 32+ byte secret. Generate with: openssl rand -hex 32
AUTH_SECRET=

# GitHub OAuth app: https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github (dev)
#               https://your-domain/api/auth/callback/github  (prod)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Google OAuth: https://console.cloud.google.com/apis/credentials
# Callback URL: http://localhost:3000/api/auth/callback/google (dev)
#               https://your-domain/api/auth/callback/google  (prod)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
