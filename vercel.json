{
  "framework": "angular",
  "buildCommand": "ng build",
  "outputDirectory": "dist/ginasio-xl-app/browser",
  "routes": [
    { "src": "/api/auth/(.*)", "dest": "/api/auth" },
    { "src": "/api/(.*)",      "dest": "/api/$1"   },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/" }
  ]
}
