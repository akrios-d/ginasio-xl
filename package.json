{
  "name": "gymdesk",
  "version": "0.6.2",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "prepare": "husky && node scripts/setup-hooks.cjs",
    "format": "prettier --write \"src/**/*.{ts,html,css}\" \"api/**/*.ts\" \"server/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,css}\" \"api/**/*.ts\" \"server/**/*.ts\"",
    "start:vercel": "ng serve --configuration=vercel",
    "test:unit": "vitest run",
    "test:ng": "ng test --no-watch",
    "test:all": "vitest run && ng test --no-watch"
  },
  "private": true,
  "type": "module",
  "dependencies": {
    "@angular/common": "^22.0.2",
    "@angular/compiler": "^22.0.2",
    "@angular/core": "^22.0.2",
    "@angular/forms": "^22.0.2",
    "@angular/platform-browser": "^22.0.2",
    "@angular/router": "^22.0.2",
    "@angular/service-worker": "^22.0.2",
    "@auth/core": "^0.41.2",
    "@auth/mongodb-adapter": "^3.11.2",
    "@vercel/functions": "^3.7.3",
    "mongodb": "^7.3.0",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@angular/build": "^22.0.4",
    "@angular/cli": "^22.0.4",
    "@angular/compiler-cli": "^22.0.2",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "angular-eslint": "22.0.0",
    "eslint": "^10.5.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.62.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "src/**/*.{ts,html,css}": [
      "prettier --write"
    ],
    "api/**/*.ts": [
      "prettier --write"
    ],
    "server/**/*.ts": [
      "prettier --write"
    ]
  }
}
